# lfg configuration — copy to .env and edit.
#
# SECURITY: the web UI / API has NO authentication. It is meant to be reached
# only over your tailnet (loopback bind + `tailscale serve`), never the public
# internet. See the "Security" section of the README.

# ---- web server ----
# Bind address. Keep 127.0.0.1 — `tailscale serve` fronts it on your tailnet.
# Setting 0.0.0.0 exposes the UNAUTHENTICATED UI to every network the box is on.
LFG_HOST=127.0.0.1
LFG_PORT=8766

# Where you keep the git repos lfg can launch agents into (scanned at runtime).
# Defaults to ~/repos.
LFG_REPOS_ROOT=
# Default single project repo agents act on (git_log / repo_files / actions /
# whatsapp). Defaults to the current working directory when unset.
LFG_REPO=

# Comma-separated emails for optional per-user session tagging (Gravatar avatars
# in the UI). Leave empty for single-user.
LFG_USERS=

# ---- Claude / report backend (used by `lfg agents`) ----
#   cli    (default) — spawns `claude -p` directly.
#   ai-sdk           — Vercel AI SDK harness (ai-sdk-provider-claude-code) that
#                      drives the same installed `claude` + subscription OAuth.
LFG_CLAUDE_BACKEND=cli
# Model for the ai-sdk backend: opus | sonnet | haiku | full id (claude-opus-4-8).
LFG_CLAUDE_MODEL=opus
# Optional override for the claude binary. Defaults to `claude` on PATH.
LFG_CLAUDE_PATH=
# Optional: an API key instead of the interactive `claude` OAuth.
ANTHROPIC_API_KEY=

# Optional: repo the security_scan collector audits. Defaults to LFG_REPO / cwd.
LFG_SECURITY_REPO=

# ---- optional: voice (TTS/STT) proxy ----
# Point at your own self-hosted TTS/STT service; the browser never sees the
# token. Leave unset to disable the voice endpoints.
TTS_UPSTREAM=
TTS_TOKEN=

# ---- optional: WhatsApp control sidecar (`lfg whatsapp`) ----
# Pair a dedicated number via the QR Baileys prints, then add it to your group.
# Use "*" only while discovering group JIDs from logs; then pin the exact
# comma-separated JID(s), e.g. 1203630xxxxxxxx@g.us.
LFG_WHATSAPP_ALLOWED_GROUPS=
LFG_WHATSAPP_AGENT=claude
LFG_WHATSAPP_AGENT_CWD=
LFG_WHATSAPP_TRIGGER=lfg
LFG_WHATSAPP_ALWAYS_ON=false
LFG_WHATSAPP_AUTH_DIR=

# ---- setup-time only (scripts/setup.sh) ----
# Tailscale auth key — used ONCE to join the tailnet, never written to disk.
# Pass it on the command line, not in this file:
#   TS_AUTHKEY=tskey-auth-… lfg setup

# ── Runtime UI extensions (optional) ─────────────────────────────────────────
# Comma-separated ESM URLs the server injects as <script type="module"> after
# the app bundle. Each module calls window.lfg.registerExtension(...) to add UI
# (e.g. a bottom-nav tab). Leave empty for a clean core.
LFG_EXTENSIONS=

# Optional same-origin backend proxy for an extension that must reach a private
# API without exposing its token to the browser. All env-driven (no defaults):
#   LFG_PROXY_PREFIX    path prefix the browser calls, e.g. "/_ext"
#   LFG_PROXY_UPSTREAM  upstream origin to forward matched requests to
#   LFG_PROXY_TOKEN     bearer token injected server-side
#   LFG_PROXY_ALLOW     comma-sep allowed upstream path prefixes (empty = all)
LFG_PROXY_PREFIX=
LFG_PROXY_UPSTREAM=
LFG_PROXY_TOKEN=
LFG_PROXY_ALLOW=

# ── iOS push notifications (APNs, optional) ──────────────────────────────────
# Push a notification to the native iOS/iPadOS app when a session finishes a
# turn or needs your input. Off unless all three of KEY/KEY_ID/TEAM_ID are set.
# Uses token-based (.p8) auth. Create an APNs Auth Key in the Apple Developer
# portal (Certificates, Identifiers & Profiles → Keys) and enable the Push
# Notifications capability for the app id.
#   LFG_APNS_KEY      inline .p8 PEM contents, or a path to the .p8 file
#   LFG_APNS_KEY_ID   the Key ID of that .p8
#   LFG_APNS_TEAM_ID  your Apple Team ID
#   LFG_APNS_TOPIC    app bundle id (default dev.omg.lfg)
LFG_APNS_KEY=
LFG_APNS_KEY_ID=
LFG_APNS_TEAM_ID=
LFG_APNS_TOPIC=
