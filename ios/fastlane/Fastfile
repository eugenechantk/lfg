# CANONICAL Fastfile — house TestFlight standard. Byte-identical across all apps.
# Per-app config comes from ENV (see .env.default). Do NOT edit per app; edit the
# template in ~/.claude/skills/testflight-deploy/templates/ and run scaffold --sync-all.
default_platform(:ios)

def required_env(name)
  value = ENV[name]
  UI.user_error!("Missing required environment variable: #{name}") if value.nil? || value.strip.empty?
  value
end

def boolean_env(name, default)
  value = ENV[name]
  return default if value.nil? || value.strip.empty?

  %w[1 true yes y].include?(value.downcase)
end

# --- Per-app config (from ENV; set in .env.default) ---
def app_identifier   = required_env("APP_IDENTIFIER")
def xcodeproj        = required_env("FASTLANE_PROJECT")      # e.g. "MyApp.xcodeproj"
def target_name      = required_env("FASTLANE_TARGET")       # e.g. "MyApp"
def scheme_name      = ENV.fetch("FASTLANE_SCHEME") { target_name }
def app_name         = ENV["APP_NAME"].to_s.strip.empty? ? app_identifier : ENV["APP_NAME"]
def uses_xcodegen?   = boolean_env("USES_XCODEGEN", false)

# Hong Kong is UTC+8 year-round (no DST) — fixed offset is safe on any CI runner.
HONG_KONG_UTC_OFFSET = "+08:00".freeze
def hong_kong_now = Time.now.getlocal(HONG_KONG_UTC_OFFSET)

def timestamp_build_number
  return ENV["BUILD_NUMBER"].strip unless ENV["BUILD_NUMBER"].to_s.strip.empty?

  # CFBundleVersion must be digits/dots only -> YYYYMMDDHHMM. Monotonic and
  # collision-free across concurrent local/CI builds (no API round-trip needed).
  hong_kong_now.strftime("%Y%m%d%H%M")
end

def testflight_changelog
  stamp = "#{hong_kong_now.strftime('%Y-%m-%d %H:%M')} (HKT)"
  changelog = ENV["TESTFLIGHT_CHANGELOG"].to_s.strip
  changelog = sh("git log -1 --pretty=%B", log: false).strip if changelog.empty?
  changelog.empty? ? stamp : "#{stamp}\n\n#{changelog}"
end

def app_store_connect_key
  app_store_connect_api_key(
    key_id:      required_env("APP_STORE_CONNECT_API_KEY_ID"),
    issuer_id:   required_env("APP_STORE_CONNECT_API_ISSUER_ID"),
    key_content: required_env("APP_STORE_CONNECT_API_KEY_BASE64"),
    is_key_content_base64: true,
    duration:    1200
  )
end

# Signing via the SHARED match repo + the single shared distribution certificate.
# readonly:false (bootstrap) creates the App Store profile for this bundle id;
# readonly:true (deploy) just fetches it.
def sync_appstore_signing(readonly:)
  match(
    type:           "appstore",
    readonly:       readonly,
    app_identifier: app_identifier,
    git_url:        required_env("MATCH_GIT_URL"),
    git_branch:     ENV.fetch("MATCH_GIT_BRANCH", "main"),
    team_id:        required_env("DEVELOPER_TEAM_ID"),
    api_key:        app_store_connect_key
  )
end

def app_store_record_exists?(identifier)
  app_store_connect_key # sets the global Spaceship::ConnectAPI token
  !Spaceship::ConnectAPI::App.find(identifier).nil?
end

def regenerate_project
  sh("cd .. && xcodegen generate") if uses_xcodegen?
end

platform :ios do
  desc "Verify the App Store Connect app record exists"
  lane :verify_app_store_record do
    unless app_store_record_exists?(app_identifier)
      UI.user_error!("No App Store Connect app record for #{app_identifier}. Run `fastlane ios create_app_record` first.")
    end
    UI.success("App Store Connect record found for #{app_identifier}.")
  end

  desc "Register the App ID and create the App Store Connect app record (headless, API-key only)"
  lane :create_app_record do
    app_store_connect_key # sets the global Spaceship::ConnectAPI token
    identifier = app_identifier
    name = app_name

    bundle = Spaceship::ConnectAPI::BundleId.all.find { |b| b.identifier == identifier }
    if bundle.nil?
      bundle = Spaceship::ConnectAPI::BundleId.create(
        name: name.gsub(/[^A-Za-z0-9 ]/, ""),
        identifier: identifier,
        platform: "IOS"
      )
      UI.success("Registered App ID #{identifier}")
    else
      UI.message("App ID #{identifier} already registered")
    end

    if Spaceship::ConnectAPI::App.find(identifier)
      UI.success("App Store Connect record already exists for #{identifier}")
    else
      Spaceship::ConnectAPI::App.create(
        name: name,
        version_string: "0.1.0",
        sku: identifier,
        primary_locale: ENV.fetch("PRIMARY_LOCALE", "en-US"),
        bundle_id: bundle.id,
        platforms: ["IOS"]
      )
      UI.success("Created App Store Connect record '#{name}' for #{identifier}")
    end
  end

  desc "Create or refresh App Store signing assets in the shared match repo (run once per app)"
  lane :bootstrap_match do
    sync_appstore_signing(readonly: false)
  end

  desc "Build a signed Release archive and upload it to TestFlight"
  lane :deploy_testflight do
    setup_ci if is_ci
    api_key = app_store_connect_key

    unless app_store_record_exists?(app_identifier)
      UI.user_error!("No App Store Connect app record for #{app_identifier}. Run `fastlane ios create_app_record` first.")
    end

    regenerate_project
    sync_appstore_signing(readonly: true)

    profile_name = "match AppStore #{app_identifier}"
    update_code_signing_settings(
      use_automatic_signing: false,
      path:                  xcodeproj,
      targets:               [target_name],
      team_id:               required_env("DEVELOPER_TEAM_ID"),
      code_sign_identity:    "Apple Distribution",
      profile_name:          profile_name
    )

    build_app(
      project:          xcodeproj,
      scheme:           scheme_name,
      configuration:    "Release",
      destination:      "generic/platform=iOS",
      clean:            true,
      export_method:    "app-store",
      output_directory: "build/fastlane",
      output_name:      "#{target_name}.ipa",
      # Build number via xcargs so the committed project is never mutated. Requires
      # Info.plist CFBundleVersion = $(CURRENT_PROJECT_VERSION) for non-XcodeGen apps.
      xcargs:           "CURRENT_PROJECT_VERSION=#{timestamp_build_number}",
      export_options: {
        signingStyle: "manual",
        provisioningProfiles: { app_identifier => profile_name }
      }
    )

    # Default: skip the processing wait for a fast, reliable upload. Attaching a
    # changelog requires waiting for the build to appear on ASC (slow + flaky), so we
    # only do that when TESTFLIGHT_WAIT_FOR_PROCESSING=true.
    wait = boolean_env("TESTFLIGHT_WAIT_FOR_PROCESSING", false)
    upload_opts = {
      api_key:                    api_key,
      ipa:                        "build/fastlane/#{target_name}.ipa",
      uses_non_exempt_encryption: false,
      skip_waiting_for_build_processing: !wait
    }
    upload_opts[:changelog] = testflight_changelog if wait
    upload_to_testflight(**upload_opts)
  end

  desc "Alias for deploy_testflight"
  lane :beta do
    deploy_testflight
  end
end
